.hero {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
  position: relative;
  padding: 120px 24px 80px;
  max-width: 900px;
  margin: 0 auto;
}

.badge {
  --badge-color: var(--accent);
  --badge-color-dim: var(--accent-dim);
  --badge-color-glow: var(--accent-glow);

  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--badge-color);
  padding: 6px 14px;
  border: 1px solid var(--badge-color-dim);
  border-radius: 100px;
  background: var(--badge-color-glow);
  margin-bottom: 32px;
  animation: fadeUp 0.8s ease both;
  text-decoration: none;
  transition:
    border-color 0.25s ease,
    background 0.25s ease;
}

.badge:hover {
  border-color: var(--badge-color);
  background: var(--badge-color-glow);
}

.badgeDot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--badge-color);
  box-shadow: 0 0 8px var(--badge-color);
  animation: pulse 2s ease infinite;
}

/* Status color variants */
.badge[data-status="available"] {
  --badge-color: #22c55e;
  --badge-color-dim: rgba(34, 197, 94, 0.15);
  --badge-color-glow: rgba(34, 197, 94, 0.25);
}

.badge[data-status="open"] {
  --badge-color: #3b82f6;
  --badge-color-dim: rgba(59, 130, 246, 0.15);
  --badge-color-glow: rgba(59, 130, 246, 0.25);
}

.badge[data-status="freelance"] {
  --badge-color: #a855f7;
  --badge-color-dim: rgba(168, 85, 247, 0.15);
  --badge-color-glow: rgba(168, 85, 247, 0.25);
}

.badge[data-status="custom"] {
  --badge-color: var(--accent);
  --badge-color-dim: var(--accent-dim);
  --badge-color-glow: var(--accent-glow);
}

.heading {
  font-family: var(--font-syne), sans-serif;
  font-weight: 800;
  font-size: clamp(40px, 8vw, 72px);
  line-height: 1.05;
  letter-spacing: -0.03em;
  margin-bottom: 24px;
  animation: fadeUp 0.8s ease 0.1s both;
}

.gradient {
  background: linear-gradient(135deg, var(--grad-from), var(--grad-to));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.sub {
  font-size: 16px;
  color: var(--text-secondary);
  max-width: 520px;
  margin-bottom: 40px;
  animation: fadeUp 0.8s ease 0.2s both;
}

.cta {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
  animation: fadeUp 0.8s ease 0.3s both;
}

.btnPrimary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-mono), monospace;
  font-size: 14px;
  font-weight: 500;
  letter-spacing: 0.04em;
  padding: 14px 28px;
  border-radius: 8px;
  text-decoration: none;
  transition: all 0.3s ease;
  background: linear-gradient(135deg, var(--grad-from), var(--grad-to));
  color: #06060e;
  border: none;
  min-height: 44px;
}

.btnPrimary:hover {
  transform: translateY(-1px);
  box-shadow: 0 4px 30px rgba(0, 212, 255, 0.26);
}

.btnGhost {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-mono), monospace;
  font-size: 14px;
  font-weight: 500;
  letter-spacing: 0.04em;
  padding: 14px 28px;
  border-radius: 8px;
  text-decoration: none;
  transition: all 0.3s ease;
  background: transparent;
  color: var(--text-secondary);
  border: 1px solid var(--border);
  min-height: 44px;
}

.btnGhost:hover {
  border-color: var(--accent);
  color: var(--accent);
}

.glow {
  position: absolute;
  top: 20%;
  right: -10%;
  width: 400px;
  height: 400px;
  background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
  filter: blur(60px);
  will-change: transform;
  animation: drift 8s ease-in-out infinite;
}
