.hero {
  min-height: calc(100vh - 80px);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 48px 24px;
}

.logo {
  font-family: var(--font-serif), Georgia, serif;
  font-size: 48px;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16px;
}

.title {
  font-family: var(--font-serif), Georgia, serif;
  font-size: clamp(32px, 6vw, 48px);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12px;
}

.tagline {
  font-size: 18px;
  color: var(--text-secondary);
  margin-bottom: 32px;
}

.nav {
  display: flex;
  gap: 32px;
}

.navLink {
  font-size: 16px;
  color: var(--text-secondary);
  text-decoration: none;
  transition: color 0.2s ease;
}

.navLink:hover {
  color: var(--accent);
}
